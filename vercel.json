 {
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "rewrites": [
      { "source": "/", "destination": "/frontend/index.html" },
      { "source": "/architecture", "destination": "/frontend/architecture.html" },
      { "source": "/js/:path*", "destination": "/frontend/js/:path*" },
      { "source": "/css/:path*", "destination": "/frontend/css/:path*" },
      { "source": "/assets/:path*", "destination": "/frontend/assets/:path*" }
    ],
    "functions": {
      "api/recommend.js": {
        "maxDuration": 20,
        "includeFiles": "{data/products.json,backend/upsells.json}"
      },
      "api/scan/foot.js": {
        "maxDuration": 30,
        "includeFiles": "backend/**"
      },
      "api/scan/gait.js": {
        "maxDuration": 30,
        "includeFiles": "backend/**"
      }
    },
    "headers": [
      {
        "source": "/frontend/(.*)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=300" }
        ]
      }
    ]
  }
