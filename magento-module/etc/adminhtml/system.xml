<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="herqua" translate="label" sortOrder="400">
            <label>Herqua</label>
        </tab>
        <section id="herqua_schoenadviseur" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Schoenadviseur</label>
            <tab>herqua</tab>
            <resource>Herqua_Schoenadviseur::config</resource>

            <group id="general" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General</label>
                <field id="enabled" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="data_source" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Data source</label>
                    <source_model>Herqua\Schoenadviseur\Model\Source\DataSource</source_model>
                </field>
            </group>

            <group id="backend" translate="label" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>AI Backend</label>
                <field id="url" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Backend URL</label>
                </field>
                <field id="auth_token" type="obscure" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Backend auth token</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
            </group>

            <group id="widget" translate="label" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Widget</label>
                <field id="asset_source" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Asset source</label>
                    <source_model>Herqua\Schoenadviseur\Model\Source\AssetSource</source_model>
                </field>
                <field id="cdn_url" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>CDN URL</label>
                    <depends><field id="asset_source">cdn</field></depends>
                </field>
                <field id="auto_embed" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Auto-embed op categorie-pagina's</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>

            <group id="sync" translate="label" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Product sync</label>
                <field id="cron_frequency" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Cron frequency</label>
                    <source_model>Herqua\Schoenadviseur\Model\Source\CronFrequency</source_model>
                </field>
                <field id="category_filter" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Category ID filter (optional)</label>
                </field>
            </group>
        </section>
    </system>
</config>
