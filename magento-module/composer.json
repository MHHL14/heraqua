{
  "name": "herqua/module-schoenadviseur",
  "description": "Herqua AI Schoenadviseur module voor Magento 2",
  "type": "magento2-module",
  "version": "2.3.0",
  "license": "proprietary",
  "require": {
    "php": ">=8.1",
    "magento/framework": "^103.0",
    "magento/module-catalog": "^104.0",
    "magento/module-backend": "^102.0",
    "magento/module-config": "^101.2",
    "magento/module-store": "^101.1",
    "magento/module-widget": "^101.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.10",
    "magento/magento-coding-standard": "*",
    "psr/log": "^3.0"
  },
  "autoload": {
    "files": ["registration.php"],
    "psr-4": {
      "Herqua\\Schoenadviseur\\": ""
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Herqua\\Schoenadviseur\\Test\\": "Test/"
    },
    "files": ["Test/Stubs/magento-stubs.php"]
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
